<resources>
    <style name="Base.Theme.SimonSays" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- dark mode -->
        <item name="colorPrimary">@color/ocean_dark</item>

        <!-- immersive theme -->
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>

        <item name="android:windowBackground">@color/ocean_dark</item>
    </style>

    <style name="Theme.SimonSays" parent="Base.Theme.SimonSays" />
</resources>